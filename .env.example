# PostgreSQL
POSTGRES_DB=threats
POSTGRES_USER=threats
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_PORT=5432

# Redis
REDIS_ADDR=redis:6379
REDIS_PORT=6379

# ClamAV
CLAMAV_ADDR=clamav:3310
CLAMAV_PORT=3310

# Ingest service
INGEST_PORT=4000
PORT=4000

# API Keys — NEVER commit real values
VIRUSTOTAL_API_KEY=your_virustotal_v3_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_v2_api_key_here

# OpenTelemetry (optional — leave empty to use stdout exporter)
OTEL_ENDPOINT=

# Set to an IP to run a detection test on startup
TEST_IP=
